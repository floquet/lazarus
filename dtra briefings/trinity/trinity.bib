@article{osti_1830870,
	abstractnote = {New measurement and assessment techniques have been applied to the radiochemical reevaluation of the Trinity Event. Thirteen trinitite samples were dissolved and analyzed using a combination of traditional decay counting methods and the mass spectrometry techniques. The resulting data were assessed using advanced simulation tools to afford a final yield determination of 24.8 $\pm$ 2 kt TNT equivalent, substantially higher than the previous U.S. Department of Energy released value of 21 kt.},
	author = {Selby, Hugh D. and Hanson, Susan K. and Meininger, Daniel and Oldham, Warren J. and Kinman, William S. and Miller, Jeffrey L. and Reilly, Sean D. and Wende, Allison M. and Berger, Jennifer L. and Inglis, Jeremy and Pollington, Anthony D. and Waidmann, Christopher R. and Meade, Roger A. and Buescher, Kevin L. and Gattiker, James R. and Vander Wiel, Scott A. and Marcy, Peter W.},
