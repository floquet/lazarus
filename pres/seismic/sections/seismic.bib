@article{osti_1996468,
	abstractnote = {The 2022 Hunga eruption was a global event recorded by all three Comprehensive Test Ban Treaty Organization (CTBTO) International Monitoring System (IMS) geophysical waveform sensor technologies: seismic, infrasound, and hydroacoustic. Large volcanic eruptions are rare and additionally present an opportunity to test seismoacoustic detection, location, and identification methods for nuclear explosion monitoring.},
